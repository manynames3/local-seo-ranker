RANK_PROVIDER=scrappa
SCRAPPA_API_KEY=
ENABLE_LIVE_SCANS=false
MAX_LIVE_GRID_POINTS=81
SCAN_ALLOWED_ORIGINS=https://local-seo-ranker.pages.dev
DEFAULT_MONTHLY_CREDITS=2500
APP_ACCESS_CODE=
ALLOW_OPEN_SIGNUPS=false
ADMIN_EMAILS=

# Cloudflare Pages also needs a D1 database binding named DB.
# AWS deploys use GitHub repository variables AWS_ROLE_ARN and AWS_REGION,
# plus GitHub secrets APP_ACCESS_CODE and SCRAPPA_API_KEY.
