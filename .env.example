# Current static demo does not read environment variables.
# Use these when adding the Cloudflare backend for live rank checks.

RANK_PROVIDER=scrappa
SCRAPPA_API_KEY=
ENABLE_LIVE_SCANS=false
MAX_LIVE_GRID_POINTS=81
SCAN_ALLOWED_ORIGINS=https://local-seo-ranker.pages.dev
SCAN_GRID_SIZE=9
SCAN_DAILY_COST_CAP_USD=10
